generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String          @id @default(cuid())
  storeId        String?
  name           String
  email          String          @unique
  password       String
  role           Role            @default(EMPLOYEE)
  isActive       Boolean         @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accounts       Account[]
  activityLogs   ActivityLog[]
  rewardEvents   RewardEvent[]
  sessions       Session[]
  stockMovements StockMovement[]
  store          Store?          @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([role])
  @@index([storeId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Store {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  phone           String?
  address         String?
  isDefault       Boolean          @default(false)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  users           User[]
  brands          Brand[]
  products        Product[]
  stockMovements  StockMovement[]
  activityLogs    ActivityLog[]
  rewardEvents    RewardEvent[]
  aiConversations AiConversation[]
  aiLeads         AiLead[]

  @@index([slug])
  @@index([isActive])
  @@index([isDefault])
  @@map("stores")
}

model Brand {
  id          String   @id @default(cuid())
  storeId     String?
  name        String   @unique
  slug        String   @unique
  logoUrl     String?
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
  store    Store?    @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([name])
  @@index([slug])
  @@index([storeId])
  @@map("brands")
}

model Product {
  id                String           @id @default(cuid())
  storeId           String?
  name              String
  description       String?          @db.Text
  sku               String           @unique
  category          String?
  brandId           String?
  imageUrl          String?
  price             Decimal          @default(0) @db.Decimal(10, 2)
  costPrice         Decimal?         @db.Decimal(10, 2)
  lowStockThreshold Int              @default(5)
  isActive          Boolean          @default(true)
  deletedAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  brand             Brand?           @relation(fields: [brandId], references: [id])
  aiConversations   AiConversation[]
  rewardEvents      RewardEvent[]
  sizes             ProductSize[]
  movements         StockMovement[]
  store             Store?           @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([sku])
  @@index([category])
  @@index([brandId])
  @@index([storeId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("products")
}

model ProductSize {
  id          String          @id @default(cuid())
  productId   String
  size        String
  quantity    Int             @default(0)
  minQuantity Int             @default(0)
  maxQuantity Int?
  price       Decimal?        @db.Decimal(10, 2)
  costPrice   Decimal?        @db.Decimal(10, 2)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  movements   StockMovement[]

  @@unique([productId, size])
  @@index([productId])
  @@map("product_sizes")
}

model StockMovement {
  id            String       @id @default(cuid())
  storeId       String?
  productId     String
  productSizeId String
  userId        String
  type          MovementType
  quantity      Int
  previousQty   Int
  newQty        Int
  reason        String?
  reference     String?
  createdAt     DateTime     @default(now())
  product       Product      @relation(fields: [productId], references: [id])
  productSize   ProductSize  @relation(fields: [productSizeId], references: [id])
  store         Store?       @relation(fields: [storeId], references: [id], onDelete: SetNull)
  user          User         @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([productSizeId])
  @@index([storeId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("stock_movements")
}

model ActivityLog {
  id        String         @id @default(cuid())
  storeId   String?
  userId    String?
  action    ActivityAction
  entity    String
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime       @default(now())
  store     Store?         @relation(fields: [storeId], references: [id], onDelete: SetNull)
  user      User?          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([storeId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@map("activity_logs")
}

model RewardEvent {
  id              String           @id @default(cuid())
  storeId         String?
  userId          String
  productId       String?
  actionType      RewardActionType
  quantity        Int
  rewardAmountMAD Decimal          @db.Decimal(10, 2)
  createdAt       DateTime         @default(now())
  store           Store?           @relation(fields: [storeId], references: [id], onDelete: SetNull)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  product         Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([storeId])
  @@index([productId])
  @@index([actionType])
  @@index([createdAt])
  @@map("reward_events")
}

model AiConversation {
  id                String   @id @default(cuid())
  storeId           String?
  message           String   @db.Text
  answer            String   @db.Text
  requestedProduct  String?
  requestedBrand    String?
  requestedCategory String?
  requestedSize     String?
  requestedColor    String?
  matchedProductId  String?
  isUnavailable     Boolean  @default(false)
  ipAddress         String?
  userAgent         String?
  source            String   @default("website")
  createdAt         DateTime @default(now())

  store          Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)
  matchedProduct Product? @relation(fields: [matchedProductId], references: [id], onDelete: SetNull)
  leads          AiLead[]

  @@index([createdAt])
  @@index([storeId])
  @@index([requestedProduct])
  @@index([requestedCategory])
  @@index([requestedSize])
  @@index([requestedColor])
  @@index([matchedProductId])
  @@index([isUnavailable])
  @@map("ai_conversations")
}

model AiLead {
  id             String     @id @default(cuid())
  storeId        String?
  conversationId String?
  name           String?
  phone          String?
  email          String?
  message        String     @db.Text
  productName    String?
  size           String?
  color          String?
  source         String     @default("website")
  status         LeadStatus @default(NEW)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  store        Store?          @relation(fields: [storeId], references: [id], onDelete: SetNull)
  conversation AiConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([storeId])
  @@index([status])
  @@index([phone])
  @@index([email])
  @@map("ai_leads")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EMPLOYEE
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  STOCK_IN
  STOCK_OUT
  STOCK_ADJUST
}

enum RewardActionType {
  PRODUCT_ADDED
  PRODUCT_SOLD
}

enum LeadStatus {
  NEW
  CONTACTED
  WON
  LOST
}
