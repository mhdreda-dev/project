# ─────────────────────────────────────────────
# DATABASE — PostgreSQL (Neon / Supabase / Render)
# ─────────────────────────────────────────────
# Use a pooled connection URL for DATABASE_URL (PgBouncer/Supabase pooler).
# Use the direct (non-pooled) connection for DIRECT_URL (used by Prisma Migrate).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/stockmaster?schema=public&sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/stockmaster?schema=public&sslmode=require"

# ─────────────────────────────────────────────
# NEXT-AUTH v5
# ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-secure-random-secret"

# Production: set to your Vercel deployment URL (no trailing slash)
# Local:      http://localhost:3000
AUTH_URL="https://your-app.vercel.app"
NEXTAUTH_URL="https://your-app.vercel.app"

# ─────────────────────────────────────────────
# APP (public — exposed to browser)
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
NEXT_PUBLIC_APP_NAME="StockMaster"
